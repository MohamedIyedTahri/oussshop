# App Settings
PORT=8000
FEED_URL=https://equip-home.tn/api/meta/meta-feed.xml

# Database Settings
# For Docker Compose, use: postgresql://postgres:postgres@db:5432/chatbot_db
# For local host access, use: postgresql://postgres:postgres@localhost:5432/chatbot_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/chatbot_db

# OpenRouter Settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free
